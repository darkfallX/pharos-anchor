# Which Pharos network to use. Anchor runs on testnet.
PHAROS_NETWORK=pharos-atlantic

# Testnet burner key that signs the agent's transactions. Never commit a real key.
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Filled in automatically by `npm run deploy` and `npm run deploy:agents`.
ANCHOR_USD_ADDRESS=
ANCHOR_VAULT_ADDRESS=
ANCHOR_AGENT_VAULT_ADDRESS=

# Savings rate in basis points. 1290 = 12.9%, mirrors the real pAlpha RealFi vault.
ANCHOR_APY_BPS=1290
ANCHOR_MAX_AMOUNT=10000

# Optional safety for public deployments. If set, POST /ask, /save, /withdraw,
# /roundup, and /goal require this value in x-anchor-action-secret or body.secret.
ANCHOR_ACTION_SECRET=

# Optional safety for Agent Mode. If set, /agent/park and /agent/recall require
# this value in x-anchor-agent-secret, x-anchor-action-secret, or body.secret.
ANCHOR_AGENT_SECRET=

# Basic in-memory request limits per client.
ANCHOR_RATE_WINDOW_MS=60000
ANCHOR_READ_RATE_LIMIT=120
ANCHOR_WRITE_RATE_LIMIT=40

# Make the chat genuinely smart with an LLM. Set ONE of these. Without a key,
# Anchor still works using a simple built-in keyword parser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Or use Claude instead (recommended):
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# Or use Google Gemini (has a free tier):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Or use OpenRouter (has genuinely free models):
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-oss-120b:free

PORT=4030
